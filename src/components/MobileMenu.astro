---
const links = [
  { href: '/about', label: 'Про нас' },
  { href: '/#services', label: 'Послуги' },
  { href: '/#pricing', label: 'Пакети' },
  { href: '/#cases', label: 'Кейси' },
  { href: '/blog', label: 'Блог' },
];
---

<button
  class="mobile-menu-button"
  type="button"
  aria-label="Відкрити меню"
  aria-controls="mobile-menu"
  aria-expanded="false"
  data-menu-open
>
  <span></span>
  <span></span>
</button>

<div class="mobile-menu" id="mobile-menu" aria-hidden="true" data-menu>
  <div class="mobile-menu__backdrop" data-menu-close></div>
  <aside class="mobile-menu__panel" aria-label="Мобільна навігація">
    <div class="mobile-menu__top">
      <a class="brand" href="/" aria-label="BH Agency головна">
        <span class="brand__mark">BH.</span>
        <span>BH Agency</span>
      </a>
      <button class="mobile-menu__close" type="button" aria-label="Закрити меню" data-menu-close>
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="m6 6 12 12M18 6 6 18" />
        </svg>
      </button>
    </div>
    <nav class="mobile-menu__nav" aria-label="Мобільне меню">
      {links.map((link) => <a href={link.href} data-menu-link>{link.label}</a>)}
    </nav>
    <a class="button button-primary mobile-menu__cta" href="https://t.me/bhagencyy">Контакт</a>
  </aside>
</div>
