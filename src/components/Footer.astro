---
const year = 2026;
const links = [
  { href: '/about', label: 'Про нас' },
  { href: '/#cases', label: 'Кейси' },
  { href: '/#services', label: 'Послуги' },
  { href: '/#pricing', label: 'Пакети' },
  { href: '/blog', label: 'Блог' },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <a class="brand" href="/" aria-label="BH Agency головна">
        <span class="brand__mark">BH.</span>
        <span>BH Agency</span>
      </a>
      <p>AI-креативна студія з України. Готово до публікації.</p>
    </div>

    <nav class="site-footer__nav" aria-label="Меню у футері">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>

    <div class="site-footer__contact">
      <a href="mailto:bhagency.ai@gmail.com">bhagency.ai@gmail.com</a>
      <a href="https://t.me/bhagencyy">Telegram @bhagencyy</a>
      <div class="site-footer__social" aria-label="Соцмережі">
        <a href="https://www.instagram.com/" aria-label="Instagram BH Agency">
          <svg aria-hidden="true" viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="16" rx="5" /><circle cx="12" cy="12" r="3.5" /><path d="M17.5 6.8h.01" /></svg>
        </a>
        <a href="https://www.threads.net/" aria-label="Threads BH Agency">
          <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M17.7 10.2c-.4-3-2.3-4.7-5.4-4.7-3.5 0-5.8 2.4-5.8 6.4 0 4.1 2.3 6.6 6 6.6 2.7 0 4.8-1.4 4.8-3.7 0-2-1.5-3.1-4.1-3.1h-1.6" /><path d="M12 14.9c-1.3 0-2.2-.6-2.2-1.5s.8-1.5 2.2-1.5h1.1c2.8 0 5.2 1.6 5.2 4.6" /></svg>
        </a>
        <a href="https://www.tiktok.com/" aria-label="TikTok BH Agency">
          <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M14 4v10.2a4 4 0 1 1-4-4" /><path d="M14 4c.6 3 2.3 4.8 5 5" /></svg>
        </a>
        <a href="https://t.me/bhagencyy" aria-label="Telegram BH Agency">
          <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M21 4 3.8 10.7c-.9.4-.8 1.6.2 1.8l4.3 1.3 1.7 5.2c.3.9 1.4 1.1 2 .4l2.4-2.8 4.5 3.3c.8.6 1.9.1 2-1L22.5 5c.1-.8-.7-1.3-1.5-1Z" /><path d="m8.4 13.8 9.8-6.2-7.8 8.7" /></svg>
        </a>
      </div>
    </div>
  </div>
  <p class="site-footer__watermark" aria-hidden="true">BH AGENCY</p>
  <div class="container site-footer__bottom">
    <span>© {year} BH Agency</span>
  </div>
</footer>
