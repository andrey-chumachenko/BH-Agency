---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — BH Agency" description="Сторінку не знайдено.">
  <section class="section not-found">
    <div class="container stack" style="--stack-gap: var(--space-6)">
      <span class="badge">404</span>
      <h1>Сторінку не знайдено</h1>
      <p>Можливо, посилання змінилось або сторінку ще не опубліковано.</p>
      <a class="button button-primary" href="/">На головну</a>
    </div>
  </section>
</Layout>
