---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Блог — BH Agency" description="Матеріали BH Agency про YouTube Growth, AI-відео та системний контент для бізнесу.">
  <section class="blog-list section">
    <div class="container stack" style="--stack-gap: var(--space-10)">
      <div class="section-heading">
        <span class="badge">Блог</span>
        <h1>Ідеї про YouTube, AI-відео і контент-системи</h1>
      </div>

      <div class="blog-list__grid">
        {posts.map((post) => (
          <article class="blog-card card">
            <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('uk-UA')}</time>
            <h2><a href={`/blog/${post.slug}`}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
            <div class="cluster">
              {post.data.tags.map((tag) => <span class="badge">{tag}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
